PORT=3001
HUGGINGFACE_TOKEN=

# Comma-separated browser origins allowed to call this API (CORS)
ALLOWED_ORIGINS=http://localhost:3000,https://hudsonferraz.github.io

# Optional single frontend URL (also added to CORS allowlist)
FRONTEND_URL=https://hudsonferraz.github.io/pokedex

# Rate limits (requests per window)
AI_RATE_LIMIT_MAX=12
AI_RATE_LIMIT_WINDOW_MS=900000
META_RATE_LIMIT_MAX=90
META_RATE_LIMIT_WINDOW_MS=60000

# Outbound fetch timeouts (milliseconds)
HF_FETCH_TIMEOUT_MS=45000
PIKALYTICS_FETCH_TIMEOUT_MS=15000

# Max JSON body size for POST /api/ai-team-tips
JSON_BODY_LIMIT=16kb
